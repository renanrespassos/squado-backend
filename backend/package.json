{
  "name": "squado-backend",
  "version": "1.0.0",
  "description": "Squado — API Backend Multi-tenant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:up": "node-pg-migrate up --migration-file-language sql --migrations-dir ../database/migrations",
    "migrate:down": "node-pg-migrate down --migration-file-language sql --migrations-dir ../database/migrations",
    "migrate:create": "node-pg-migrate create --migration-file-language sql --migrations-dir ../database/migrations",
    "migrate:status": "node-pg-migrate up --dry-run --migration-file-language sql --migrations-dir ../database/migrations"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "node-pg-migrate": "^7.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
