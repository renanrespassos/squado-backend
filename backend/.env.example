# ═══════════════════════════════════════════
# SQUADO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ═══════════════════════════════════════════

# ── Banco de dados PostgreSQL ────────────────────────────────────
# Local:   postgresql://usuario:senha@localhost:5432/squado
# Cloud SQL via socket: postgresql://user:senha@/squadodb?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://usuario:senha@localhost:5432/squado

# Conexão SSL com Postgres
# - 'disable' para Cloud SQL via Unix socket (default em produção)
# - 'require' para conexões TCP em provedores externos
PGSSLMODE=disable

# ── Auth ─────────────────────────────────────────────────────────
# Gere uma chave forte:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_jwt_secreta_aqui

# ── Servidor ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Nível de log do pino: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────────
# Lista separada por vírgula. Use '*' apenas em desenvolvimento.
# Em produção: https://squado.com.br,https://www.squado.com.br
FRONTEND_URL=http://localhost:3000

# ── Admin ────────────────────────────────────────────────────────
# Lista separada por vírgula. Esses emails têm acesso a /api/admin/*
ADMIN_EMAILS=seu@email.com
