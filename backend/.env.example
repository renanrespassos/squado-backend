# ═══════════════════════════════════════════
# SQUADO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ═══════════════════════════════════════════

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/squado

# JWT — gere uma chave forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_jwt_secreta_aqui

# Ambiente
NODE_ENV=development
PORT=3001

# Frontend (CORS)
FRONTEND_URL=http://localhost:3000

# Mercado Pago (pagamentos)
MP_ACCESS_TOKEN=seu_token_mercadopago
MP_WEBHOOK_SECRET=seu_webhook_secret

# Email (para notificações)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_app
EMAIL_FROM=noreply@squado.com.br
